# dependencies
**/node_modules
**/.pnp
**/.pnp.js
**/.yarn/install-state.gz

# testing
**/coverage

# next.js
**/.next/
**/out/

# production
**/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.private.key

# credentials and keys
*.key
*.cert
*.cert.pem
*.key.pem

# vercel
.vercel

# typescript
**/*.tsbuildinfo
next-env.d.ts

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo

# Project specific
backend/.data/
backend/migrations/*.db
*.pyc
